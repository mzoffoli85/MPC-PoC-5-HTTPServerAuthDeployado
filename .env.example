# Copiar a .env y completar. Nunca commitear el .env real.

# Token que deben presentar los clientes en el header:
#   Authorization: Bearer <AUTH_TOKEN>
# Generar uno fuerte, por ejemplo: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=

# Puerto local (Cloud Run lo sobreescribe con su propio $PORT en runtime).
PORT=8000
