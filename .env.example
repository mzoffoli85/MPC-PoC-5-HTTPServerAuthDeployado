# Copiar a .env y completar. Nunca commitear el .env real.

# Token que deben presentar los clientes en el header:
#   Authorization: Bearer <AUTH_TOKEN>
# Generar uno fuerte, por ejemplo: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=

# Puerto local (Cloud Run lo sobreescribe con su propio $PORT en runtime).
PORT=8000

# Hostnames adicionales permitidos para el header Host (protección anti DNS-rebinding
# del SDK mcp). localhost/127.0.0.1 ya están permitidos por default, no hace falta
# tocar esto en local. En Cloud Run, el workflow de CI lo setea automáticamente al
# hostname público real del servicio — ver README, sección CI/CD.
# Formato: lista separada por comas, sin esquema (sin "https://"), ej:
# MCP_ALLOWED_HOSTS=mi-servicio-123456.us-central1.run.app
MCP_ALLOWED_HOSTS=
